# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: LiteLLM model identifier (default: openai/gpt-4o)
# Examples: openai/gpt-4o, openai/gpt-4o-mini, anthropic/claude-sonnet-4-20250514
AGENT_MODEL=openai/gpt-4o

# Optional: LLM temperature (default: 0.0 for deterministic output)
AGENT_TEMPERATURE=0.0
